NODE_ENV=development
PORT=3000

# Supavisor transaction pooler (runtime — port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct / session connection (migrations — port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT signing key (min 32 chars) — generate with: openssl rand -base64 32
JWT_SECRET=

# Access token TTL (default: 15m)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token TTL (default: 7d)
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth — Web client ID (used to verify ID tokens from mobile)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Optional: comma-separated client IDs (web, ios, android)
# GOOGLE_CLIENT_IDS=
