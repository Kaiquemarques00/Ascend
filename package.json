{
  "name": "ascend",
  "version": "0.1.0",
  "private": true,
  "description": "ASCEND — Consistência que transforma",
  "workspaces": [
    "apps/*"
  ],
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "dev": "concurrently -n api,mobile -c blue,magenta \"npm run dev -w api --if-present\" \"npm run dev -w mobile --if-present\"",
    "dev:api": "npm run dev -w api --if-present",
    "dev:mobile": "npm run dev -w mobile --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . && npm run lint --workspaces --if-present",
    "format": "prettier --write"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
